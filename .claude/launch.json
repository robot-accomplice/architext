{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "corpus-review",
      "runtimeExecutable": "node",
      "runtimeArgs": ["/tmp/ax-review-serve.mjs"],
      "port": 4173
    },
    {
      "name": "viewer",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd crates/architext-viewer && trunk serve --address 127.0.0.1 --port 8099 --no-autoreload"],
      "port": 8099
    },
    {
      "name": "viewer-serve",
      "runtimeExecutable": "target/release/architext-serve",
      "runtimeArgs": ["--data-dir", "docs/architext/data", "--dist", "crates/architext-viewer/dist", "--port", "8110"],
      "port": 8110
    },
    {
      "name": "viewer-corpus",
      "runtimeExecutable": "target/release/architext-serve",
      "runtimeArgs": ["--data-dir", "test/fixtures/corpus", "--dist", "crates/architext-viewer/dist", "--port", "8110"],
      "port": 8110
    }
  ]
}
