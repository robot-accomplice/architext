{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://architext.local/schema/flows.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["flows"],
  "properties": {
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "status",
          "summary",
          "trigger",
          "actors",
          "steps",
          "guarantees",
          "failureBehavior",
          "observability",
          "verification",
          "knownGaps"
        ],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["planned", "partial", "implemented"] },
          "summary": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 },
          "actors": { "$ref": "#/$defs/idList" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "from", "to", "action", "summary", "data"],
              "properties": {
                "id": { "$ref": "#/$defs/id" },
                "from": { "$ref": "#/$defs/id" },
                "to": { "$ref": "#/$defs/id" },
                "kind": {
                  "type": "string",
                  "enum": ["process", "decision", "start", "stop", "request", "return", "async", "persistence", "self", "artifact"]
                },
                "returnOf": { "$ref": "#/$defs/id" },
                "outcome": { "type": "string", "minLength": 1 },
                "action": { "type": "string", "minLength": 1 },
                "summary": { "type": "string", "minLength": 1 },
                "data": { "$ref": "#/$defs/idList" }
              }
            }
          },
          "sequenceFrames": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "label", "stepIds"],
              "properties": {
                "id": { "$ref": "#/$defs/id" },
                "type": {
                  "type": "string",
                  "enum": ["loop", "optional", "retry", "transaction"]
                },
                "label": { "type": "string", "minLength": 1 },
                "stepIds": { "$ref": "#/$defs/idList" }
              }
            }
          },
          "guarantees": { "$ref": "#/$defs/stringList" },
          "failureBehavior": { "$ref": "#/$defs/stringList" },
          "observability": { "$ref": "#/$defs/stringList" },
          "verification": { "$ref": "#/$defs/stringList" },
          "knownGaps": { "$ref": "#/$defs/stringList" }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "idList": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
