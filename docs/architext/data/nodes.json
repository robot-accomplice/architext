      "owner": "Project maintainers",
      "sourcePaths": [],
      "runtime": "Terminal workflow",
      "interfaces": ["architext CLI"],
      "dependencies": ["architext-cli"],
      "dataHandled": ["architecture-model", "repository-metadata", "agent-instructions"],
