{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://architext.local/schema/views.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["views"],
  "properties": {
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type", "summary", "lanes"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["system-map", "flow-explorer", "c4-context", "c4-container", "c4-component", "dataflow", "deployment", "risk-overlay"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "lanes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "nodeIds"],
              "properties": {
                "id": { "$ref": "#/$defs/id" },
                "name": { "type": "string", "minLength": 1 },
                "nodeIds": { "$ref": "#/$defs/idList" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "idList": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" }
    }
  }
}

