{
  "name": "@robotaccomplice/architext",
  "version": "1.6.2",
  "description": "Local JSON-backed architecture and dataflow viewer for engineering teams and LLM-maintained architecture maps.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "architext": "tools/architext-adopt.mjs"
  },
  "files": [
    ".codex-plugin",
    "docs/architecture",
    "docs/assets/screenshots",
    "docs/architext/data",
    "viewer/dist",
    "viewer/src",
    "viewer/schema",
    "viewer/tools",
    "viewer/public",
    "viewer/index.html",
    "viewer/package.json",
    "viewer/package-lock.json",
    "viewer/tsconfig.json",
    "viewer/vite.config.ts",
    "viewer/AGENTS_APPENDIX.md",
    "viewer/LLM_ARCHITEXT.md",
    "viewer/README.md",
    "skills",
    "src",
    "tools",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "architext": "architext serve .",
    "architext:build": "architext build .",
    "architext:clean": "architext clean .",
    "architext:doctor": "architext doctor .",
    "architext:prompt": "architext prompt .",
    "architext:validate": "architext validate .",
    "build": "npm --prefix viewer run build",
    "cli": "node tools/architext-adopt.mjs",
    "doctor": "node tools/architext-adopt.mjs doctor --target .",
    "prepack": "npm run build",
    "test": "node --test test/*.test.mjs",
    "test:all": "npm test",
    "test:benchmark": "node --test test/c4-documents.test.mjs test/routing-fitness.test.mjs test/routing-corpus-fitness.test.mjs",
    "test:uat": "node scripts/uat-harness.mjs",
    "check:install-docs": "node scripts/check-install-docs.mjs",
    "validate": "node viewer/tools/validate-architext.mjs --data-dir docs/architext/data",
    "verify": "npm run check:install-docs && npm test && npm run validate && npm run build && npm run test:benchmark",
    "release:check": "npm run verify && npm run test:uat && npm pack --dry-run && npm run smoke:pack",
    "smoke:pack": "node scripts/smoke-packed-cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robot-accomplice/architext.git"
  },
  "keywords": [
    "architecture",
    "c4",
    "dataflow",
    "documentation",
    "llm",
    "schema"
  ],
  "author": "Robot Accomplice",
  "bugs": {
    "url": "https://github.com/robot-accomplice/architext/issues"
  },
  "homepage": "https://github.com/robot-accomplice/architext#readme"
}
