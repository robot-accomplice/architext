{
  "name": "@robotaccomplice/architext",
  "version": "1.7.2",
  "description": "Local JSON-backed architecture and dataflow viewer for engineering teams and LLM-maintained architecture maps. Rust-native CLI + WASM viewer.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "architext": "tools/architext-adopt.mjs"
  },
  "files": [
    ".codex-plugin",
    "docs/architecture",
    "docs/assets/screenshots",
    "docs/architext/data",
    "crates/architext-viewer/dist",
    "viewer/schema",
    "viewer/AGENTS_APPENDIX.md",
    "viewer/LLM_ARCHITEXT.md",
    "viewer/README.md",
    "skills",
    "tools",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "architext": "architext serve .",
    "architext:build": "architext build .",
    "architext:clean": "architext clean .",
    "architext:doctor": "architext doctor .",
    "architext:prompt": "architext prompt .",
    "architext:validate": "architext validate .",
    "build:viewer": "trunk build --release --config crates/architext-viewer/Trunk.toml",
    "prepack": "npm run build:viewer",
    "check:install-docs": "node scripts/check-install-docs.mjs",
    "validate": "cargo run --quiet -p architext-cli -- validate .",
    "verify": "npm run check:install-docs && npm run validate && npm run build:viewer",
    "release:check": "npm run verify && npm pack --dry-run && npm run smoke:pack",
    "smoke:pack": "node scripts/smoke-packed-cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@robotaccomplice/architext-darwin-arm64": "1.7.2",
    "@robotaccomplice/architext-darwin-x64": "1.7.2",
    "@robotaccomplice/architext-linux-x64": "1.7.2",
    "@robotaccomplice/architext-linux-arm64": "1.7.2",
    "@robotaccomplice/architext-win32-x64": "1.7.2"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robot-accomplice/architext.git"
  },
  "keywords": [
    "architecture",
    "c4",
    "dataflow",
    "documentation",
    "llm",
    "schema"
  ],
  "author": "Robot Accomplice",
  "bugs": {
    "url": "https://github.com/robot-accomplice/architext/issues"
  },
  "homepage": "https://github.com/robot-accomplice/architext#readme"
}
